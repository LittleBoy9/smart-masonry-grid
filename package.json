{
  "name": "smart-masonry-grid",
  "version": "0.2.0",
  "homepage": "https://littleboy9.github.io/smart-masonry-grid/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LittleBoy9/smart-masonry-grid.git"
  },
  "bugs": {
    "url": "https://github.com/LittleBoy9/smart-masonry-grid/issues"
  },
  "description": "A zero-dependency, virtualized masonry grid layout library",
  "type": "module",
  "author": {
    "name": "Sounak Das",
    "email": "contact@sounakdas.in",
    "url": "https://sounakdas.in"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "require": {
        "types": "./dist/react/index.d.cts",
        "default": "./dist/react/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "masonry",
    "grid",
    "layout",
    "virtualized",
    "vanilla",
    "typescript",
    "zero-dependency",
    "resize-observer",
    "ssr",
    "react",
    "nextjs",
    "react-masonry",
    "masonry-grid"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
